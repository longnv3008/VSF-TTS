APP_NAME=VinSmart Audio Pipeline
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000

BACKEND_PORT=8001
FRONTEND_PORT=5174

POSTGRES_HOST=localhost
POSTGRES_DB=audio_pipeline
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=5434

DATABASE_URL=

STORAGE_ROOT=./data
RAW_YOUTUBE_DIR=./data/raw/youtube
PROCESSED_AUDIO_DIR=./data/processed/audio
METADATA_DIR=./data/metadata
LABELING_UPLOAD_DIR=./data/labeling/upload
LOG_DIR=./logs

# Segment-level pipeline (VAD ONNX nội bộ + cắt câu + ASR fallback)
SEGMENTS_DIR=./data/processed/segments
VAD_MODEL_PATH=../VAD/models/vad/1/vad.onnx
VAD_THRESHOLD=0.7
VAD_MIN_VOLUME=0.6
VAD_START_SECS=0.1
VAD_STOP_SECS=0.6
VAD_CHUNK_MS=64
SENTENCE_MAX_SEC=12.0
SENTENCE_MIN_SEC=0.3
PHRASE_GAP_SEC=0.45

# Nếu USE_VTT_TRANSCRIPT=true thì dùng vtt để ra output còn false thì phải qua ASR
USE_VTT_TRANSCRIPT=true

SEGMENT_PAD_SEC=0.35
SEGMENT_MIN_SEC=0.3
SEGMENT_BOUNDARY_SLACK_SEC=0.8
SEGMENT_MERGE_GAP_SEC=0.5
VTT_OVERLAP_SEC=0.2
ASR_MODEL=large-v3
ASR_DEVICE=auto
# ASR hardening chống ảo giác khoảng lặng (mặc định = bật).
ASR_NO_SPEECH_THRESHOLD=0.6
ASR_LOGPROB_MIN=-1.0
ASR_VAD_FILTER=true
DEMUCS_ENABLED=true
DEMUCS_MODE=auto
DEMUCS_COMMAND=python -m demucs
DEMUCS_MODEL=htdemucs
DEMUCS_DEVICE=cuda

CRAWL_MIN_DELAY_SEC=2.0
CRAWL_MAX_DELAY_SEC=8.0
CRAWL_JOB_COOLDOWN_SEC=5.0
CRAWL_BLOCK_COOLDOWN_SEC=900.0
CRAWL_URL_RETRY_LIMIT=4
INGEST_URLS_PER_JOB=50
DISCOVERY_ENABLED=true
DISCOVERY_BATCH_SIZE=20
DISCOVERY_CYCLE_LIMIT_PER_START=20
DISCOVERY_MIN_DELAY_SEC=5.0
DISCOVERY_MAX_DELAY_SEC=100.0
DISCOVERY_TOPIC_FILE=topic.txt
DISCOVERY_QUERY_WINDOW_SIZE=20
DISCOVERY_SEARCH_QUERIES=tin tuc viet nam;am nhac viet nam;phong su viet nam;podcast tieng viet
YT_DLP_COOKIE_FILE=/app/cookies/youtube.txt
YT_DLP_COOKIE_BACKUP_FILE=/app/cookies/youtube_backup.txt

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=audio-pipeline
LANGCHAIN_API_KEY=

TELEGRAM_LOG_ENABLED=true
TELEGRAM_BOT_TOKEN=8977457912:AAGb5qK-RJ_smmKkz_dokkMdes-2QyuqfHg
TELEGRAM_CHAT_ID=-5205018126

RESUME_INCOMPLETE_JOBS_ON_STARTUP=false

LABELING_API_URL=
LABELING_API_KEY=
